gitignore
# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.pytest-tmp/

# Virtual Environment
.venv/
venv/
.test-deps/

# IDE
.vscode/
.idea/

# Environment Variables
.env
.env.*
!.env.example

# Build Files
build/
dist/
package/
*.zip

# Raw Generated Data
data/raw/*.json
!data/raw/.gitkeep
data/test_raw/
